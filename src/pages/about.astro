---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Yuxuan Wang" description="About Yuxuan Wang — Data Scientist specializing in clinical NLP and production ML">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by. Read below to learn more about myself and my background."
			>
				<img
					width="1553"
					height="873"
					src="/assets/at-work.jpg"
					alt="Yuxuan Wang at work"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						Machine learning engineer focused on clinical NLP and medical coding automation — building
						systems where model decisions carry real consequences and accuracy is measured in healthcare
						outcomes, not just benchmarks.
					</p>
					<p>
						At XpertDox, I work across the full stack: redesigning data infrastructure, training and
						owning production models, and translating performance into the business metrics that actually
						matter to clinical and product stakeholders. The scope has grown significantly — from a narrow
						ICD classifier to a platform covering CPT, ICD, and billing across 2,000 codes — and so has
						the responsibility to keep it reliable, scalable, and medically sound.
					</p>
					<p>
						Before this, I worked across media and healthcare during my M.S. at NYU — forecasting at
						NBCUniversal, predictive modeling for non-invasive glucose monitoring — building the range
						that makes domain-specific depth more useful. What I'm drawn to is work with staying power:
						problems where careful modeling, domain understanding, and engineering discipline create
						something that holds value as the tools around it continue to evolve.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p><strong>New York University</strong> — M.S. Data Science, 2023–2025 (GPA 3.95)<br />
					Coursework: ML System Design, NLP, Deep Learning, Big Data, Probabilistic Time Series Analysis<br />
					Teaching Assistant: Big Data, Intro to Data Science</p>
					<p><strong>NYU Shanghai</strong> — B.S. Data Science (AI concentration) &amp; Economics, 2018–2022 (GPA 3.78 major / 3.69 overall)<br />
					Coursework: Reinforcement Learning, Information Visualization, Database Systems, Data Structures<br />
					Honors: Dean's List, Business &amp; Economics Honors Capstone</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<p><strong>Languages &amp; Frameworks:</strong> Python, SQL, PyTorch, Spark, FastAPI, MLflow, ONNX</p>
					<p><strong>Domains:</strong> Clinical NLP, Medical Coding Automation, Time Series Forecasting, Computer Vision, Reinforcement Learning, Self-Supervised Learning</p>
					<p><strong>Practices:</strong> MLOps, Production Model Ownership, Data Drift Monitoring, Prompt Engineering, Distributed Systems</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
