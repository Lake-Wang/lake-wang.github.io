---
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const allWork = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const experience = allWork.filter((e) => e.data.type === 'experience');
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Hello, my name is Yuxuan Wang"
					tagline="I am a Data Scientist specializing in clinical NLP and production ML — currently based in Phoenix, Arizona."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="terminal-window" size="1.33em" /> Data Scientist</Pill>
						<Pill><Icon icon="code" size="1.33em" /> ML Engineer</Pill>
						<Pill><Icon icon="pencil-line" size="1.33em" /> Researcher</Pill>
					</div>
				</Hero>

				<img
					alt="Yuxuan Wang"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Work Highlights</h3>
					<p>Current and most recent roles. The Work page has the full experience history and academic projects.</p>
				</header>

				<div class="gallery">
					<Grid>
						{experience.map((project) => (
							<li><PortfolioPreview project={project} /></li>
						))}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="domains">
				<h2 class="section-subhead">Application Domains</h2>
				<p class="domains-intro">ML and data science applied outside of pure tech — across four industries where domain depth and business translation matter as much as model quality.</p>
				<div class="domain-grid">
					<a href="/work/#fosun" class="domain-card">
						<span class="domain-label">Healthcare</span>
						<p class="domain-desc">Clinical NLP and medical coding automation at scale; predictive modeling for non-invasive medical devices</p>
						<div class="domain-orgs">
							<span>XpertDox</span>
							<span>Fosun</span>
						</div>
					</a>
					<a href="/work/#haitong-securities" class="domain-card">
						<span class="domain-label">Finance</span>
						<p class="domain-desc">Deep RL for quantitative trading strategy; equity research and securities analysis</p>
						<div class="domain-orgs">
							<span>Haitong Securities</span>
							<span>Guosheng Securities</span>
						</div>
					</a>
					<a href="/work/" class="domain-card">
						<span class="domain-label">Media & Entertainment</span>
						<p class="domain-desc">Hierarchical demand forecasting across 11 digital streaming platforms for ad sales and finance planning</p>
						<div class="domain-orgs">
							<span>NBCUniversal</span>
						</div>
					</a>
					<a href="/work/#urban-science" class="domain-card">
						<span class="domain-label">Consulting</span>
						<p class="domain-desc">Applied ML for customer retention and automotive after-sales analytics for enterprise clients</p>
						<div class="domain-orgs">
							<span>Urban Science</span>
						</div>
					</a>
				</div>
			</section>

			<section class="education">
				<h2 class="section-subhead">Education</h2>
				<div class="edu-entries">
					<div class="edu-entry">
						<div class="edu-row">
							<span class="edu-school">New York University</span>
							<span class="edu-dates">2023 – 2025</span>
						</div>
						<p class="edu-degree">M.S. Data Science &nbsp;·&nbsp; GPA 3.95</p>
						<p class="edu-note">ML System Design · NLP · Deep Learning &nbsp;·&nbsp; TA: Big Data, Intro to Data Science</p>
					</div>
					<div class="edu-entry">
						<div class="edu-row">
							<span class="edu-school">NYU Shanghai</span>
							<span class="edu-dates">2018 – 2022</span>
						</div>
						<p class="edu-degree">B.S. Data Science (AI) &amp; Economics &nbsp;·&nbsp; GPA 3.69</p>
						<p class="edu-note">Reinforcement Learning · Database · Machine Learning · Econometrics</p>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section-subhead {
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.section-subhead {
			font-size: var(--text-2xl);
		}
	}

	/* ====================================================== */

	.domains {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.domains-intro {
		font-size: var(--text-sm);
		color: var(--gray-400);
		max-width: 60ch;
	}

	.domain-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	@media (min-width: 50em) {
		.domain-grid {
			grid-template-columns: 1fr 1fr;
		}

		.domains-intro {
			font-size: var(--text-md);
		}
	}

	.domain-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.25rem 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		background: var(--gradient-subtle);
		text-decoration: none;
		color: inherit;
		transition: border-color var(--theme-transition), box-shadow var(--theme-transition);
	}

	.domain-card:hover {
		border-color: var(--accent-regular);
		box-shadow: var(--shadow-sm);
	}

	.domain-label {
		font-size: var(--text-lg);
		font-weight: 700;
		font-family: var(--font-brand);
		color: var(--gray-0);
	}

	.domain-desc {
		font-size: var(--text-sm);
		color: var(--gray-300);
		line-height: 1.55;
		flex: 1;
	}

	.domain-orgs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.35rem;
	}

	.domain-orgs span {
		font-size: var(--text-sm);
		color: var(--gray-400);
		background: var(--gray-900);
		padding: 0.15rem 0.6rem;
		border-radius: 0.4rem;
	}

	/* ====================================================== */

	.education {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.edu-entries {
		display: flex;
		flex-direction: column;
		border-top: 1px dashed var(--gray-700);
	}

	.edu-entry {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 1rem 0;
		border-bottom: 1px dashed var(--gray-700);
	}

	.edu-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}

	.edu-school {
		font-size: var(--text-md);
		font-weight: 600;
		color: var(--gray-0);
	}

	.edu-dates {
		font-size: var(--text-sm);
		color: var(--gray-400);
		font-family: var(--font-brand);
		flex-shrink: 0;
	}

	.edu-degree {
		font-size: var(--text-sm);
		color: var(--gray-300);
	}

	.edu-note {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin-top: 0.1rem;
	}

	@media (min-width: 50em) {
		.edu-school {
			font-size: var(--text-lg);
		}

		.edu-degree,
		.edu-note {
			font-size: var(--text-md);
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}
</style>
