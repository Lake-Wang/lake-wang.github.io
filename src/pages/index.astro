---
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const allWork = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const experience = allWork.filter((e) => e.data.type === 'experience');
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Hello, my name is Yuxuan Wang"
					tagline="Machine learning engineer focused on systems that work in production — not just models that perform on paper. I specialize in clinical NLP, with experience across healthcare, media, and finance. The through-line: reliable systems, measurable impact, and models that earn the trust of the workflows they're embedded in. Based in Phoenix, Arizona."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="terminal-window" size="1.33em" /> Data Scientist</Pill>
						<Pill><Icon icon="code" size="1.33em" /> ML Engineer</Pill>
						<Pill><Icon icon="pencil-line" size="1.33em" /> Researcher</Pill>
					</div>
				</Hero>

				<img
					alt="Yuxuan Wang"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Work Highlights</h3>
					<p>Current and most recent roles. The Work page has the full experience history and academic projects.</p>
				</header>

				<div class="gallery">
					<Grid>
						{experience.map((project) => (
							<li><PortfolioPreview project={project} /></li>
						))}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="domains">
				<h2 class="section-subhead">Application Domains</h2>
				<p class="domains-intro">Each domain shaped a different part of the practice — a different data intuition, a different standard for what "working" means, a different relationship with domain experts. Click any company to explore the work. <span class="hub-fn">*Pinch to zoom on mobile.</span></p>

				<div class="hub-diagram">
					<svg viewBox="0 0 900 390" class="hub-svg" xmlns="http://www.w3.org/2000/svg">
						<defs>
							<style>
								.hub-el { fill: var(--accent-regular); }
								.hub-tx { fill: white; font-weight: 700; font-size: 26px; font-family: var(--font-brand), system-ui, sans-serif; }
								.spoke { fill: none; stroke-linecap: round; }
								.sp-hc { stroke: var(--gray-300); stroke-width: 4; }
								.sp-me { stroke: var(--gray-400); stroke-width: 2.5; }
								.sp-fi { stroke: var(--gray-500); stroke-width: 1.5; }
								.ind-el { fill: var(--gray-900); stroke: var(--gray-600); stroke-width: 1.5; }
								.ie-fi { stroke: var(--gray-700); stroke-width: 1; }
								.ttl { font-family: var(--font-brand), system-ui, sans-serif; font-weight: 700; }
								.ttl-hc { fill: var(--accent-regular); font-size: 20px; }
								.ttl-me { fill: var(--gray-0); font-size: 16px; }
								.ttl-fi { fill: var(--gray-0); font-size: 15px; }
								.desc { fill: var(--gray-200); font-size: 12px; font-family: system-ui, sans-serif; }
								.chip { fill: var(--gray-700); }
								.chip-tx { fill: var(--gray-300); font-size: 11px; font-family: var(--font-brand), system-ui, sans-serif; }
								.clnk { cursor: pointer; text-decoration: none; }
								.clnk:hover .chip { fill: var(--accent-regular); }
								.clnk:hover .chip-tx { fill: white; }
								.tlnk { cursor: pointer; text-decoration: none; }
								.tlnk:hover .ttl { fill: var(--accent-regular); }
							</style>
						</defs>

						<!-- Hub -->
						<ellipse cx="450" cy="75" rx="130" ry="52" class="hub-el" />
						<text x="450" y="83" text-anchor="middle" class="hub-tx">AI / ML</text>

						<!-- Spokes — thicker to primary (HC center), thinner to secondary/tertiary -->
						<line x1="340" y1="103" x2="247" y2="210" class="spoke sp-me" />
						<line x1="450" y1="127" x2="450" y2="172" class="spoke sp-hc" />
						<line x1="558" y1="103" x2="664" y2="217" class="spoke sp-fi" />

						<!-- ── Media & Entertainment (left, secondary) ── -->
						<ellipse cx="155" cy="260" rx="108" ry="95" class="ind-el" />
						<a href="/work/h20/" class="tlnk">
							<text x="155" y="227" text-anchor="middle" class="ttl ttl-me">Media &amp;</text>
							<text x="155" y="245" text-anchor="middle" class="ttl ttl-me">Entertainment</text>
						</a>
						<text x="155" y="263" text-anchor="middle" class="desc">Hierarchical demand forecasting</text>
						<text x="155" y="278" text-anchor="middle" class="desc">across 11 digital platforms</text>
						<a href="/work/h20/" class="clnk">
							<rect x="86" y="294" width="138" height="18" rx="5" class="chip" />
							<text x="155" y="307" text-anchor="middle" class="chip-tx">NBCUniversal</text>
						</a>

						<!-- ── Healthcare (center, primary — largest, accent title) ── -->
						<ellipse cx="450" cy="272" rx="115" ry="100" class="ind-el" />
						<a href="/work/bloom-box/" class="tlnk">
							<text x="450" y="244" text-anchor="middle" class="ttl ttl-hc">Healthcare</text>
						</a>
						<text x="450" y="265" text-anchor="middle" class="desc">Clinical NLP · medical coding</text>
						<text x="450" y="280" text-anchor="middle" class="desc">automation · glucose prediction</text>
						<a href="/work/bloom-box/" class="clnk">
							<rect x="378" y="297" width="80" height="18" rx="5" class="chip" />
							<text x="418" y="310" text-anchor="middle" class="chip-tx">XpertDox</text>
						</a>
						<a href="/work/#fosun" class="clnk">
							<rect x="466" y="297" width="56" height="18" rx="5" class="chip" />
							<text x="494" y="310" text-anchor="middle" class="chip-tx">Fosun</text>
						</a>

						<!-- ── Finance (right, tertiary — smallest) ── -->
						<ellipse cx="745" cy="260" rx="95" ry="82" class="ind-el ie-fi" />
						<a href="/work/#haitong-securities" class="tlnk">
							<text x="745" y="231" text-anchor="middle" class="ttl ttl-fi">Finance</text>
						</a>
						<text x="745" y="250" text-anchor="middle" class="desc">Deep RL for quantitative</text>
						<text x="745" y="265" text-anchor="middle" class="desc">trading strategy</text>
						<a href="/work/#haitong-securities" class="clnk">
							<rect x="669" y="281" width="152" height="18" rx="5" class="chip" />
							<text x="745" y="294" text-anchor="middle" class="chip-tx">Haitong Securities</text>
						</a>
					</svg>
				</div>
			</section>

			<Skills />

			<section class="education">
				<h2 class="section-subhead">Education</h2>
				<div class="edu-entries">
					<div class="edu-entry">
						<div class="edu-row">
							<span class="edu-school">New York University</span>
							<span class="edu-dates">2023 – 2025</span>
						</div>
						<p class="edu-degree">M.S. Data Science &nbsp;·&nbsp; GPA 3.95</p>
						<p class="edu-note">ML System Design · NLP · Deep Learning &nbsp;·&nbsp; TA: Big Data, Intro to Data Science</p>
					</div>
					<div class="edu-entry">
						<div class="edu-row">
							<span class="edu-school">NYU Shanghai</span>
							<span class="edu-dates">2018 – 2022</span>
						</div>
						<p class="edu-degree">B.S. Data Science (AI) &amp; Economics &nbsp;·&nbsp; GPA 3.69</p>
						<p class="edu-note">Reinforcement Learning · Database · Machine Learning · Econometrics</p>
					</div>
				</div>
			</section>
			<section class="about-invite">
				<p class="invite-line">There's more to the story than the work history.</p>
				<p class="invite-sub">Background, how I think about the work, and what I do outside of ML.</p>
				<a href="/about/" class="invite-link">Read About Me <span aria-hidden="true">→</span></a>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles { display: none; }

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}
		.roles { margin-top: 0.5rem; display: flex; gap: 0.5rem; }
		.hero img { aspect-ratio: 3 / 4; border-radius: 4.5rem; object-fit: cover; }
	}

	/* ====================================================== */

	.section-subhead {
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.section-subhead { font-size: var(--text-2xl); }
	}

	/* ====================================================== */

	.domains {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.domains-intro {
		font-size: var(--text-sm);
		color: var(--gray-400);
		max-width: 62ch;
		line-height: 1.6;
	}

	@media (min-width: 50em) {
		.domains-intro { font-size: var(--text-md); }
	}

	.hub-diagram { width: 100%; }

	.hub-svg {
		width: 100%;
		height: auto;
		display: block;
		overflow: visible;
	}

	.hub-fn {
		font-size: 0.85em;
		color: var(--gray-500);
	}

	/* ====================================================== */

	.education {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.edu-entries {
		display: flex;
		flex-direction: column;
		border-top: 1px dashed var(--gray-700);
	}

	.edu-entry {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 1rem 0;
		border-bottom: 1px dashed var(--gray-700);
	}

	.edu-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}

	.edu-school { font-size: var(--text-md); font-weight: 600; color: var(--gray-0); }
	.edu-dates { font-size: var(--text-sm); color: var(--gray-400); font-family: var(--font-brand); flex-shrink: 0; }
	.edu-degree { font-size: var(--text-sm); color: var(--gray-300); }
	.edu-note { font-size: var(--text-sm); color: var(--gray-400); margin-top: 0.1rem; }

	@media (min-width: 50em) {
		.edu-school { font-size: var(--text-lg); }
		.edu-degree, .edu-note { font-size: var(--text-md); }
	}

	/* ====================================================== */

	.about-invite {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.invite-line {
		font-size: var(--text-lg);
		font-weight: 600;
		color: var(--gray-0);
	}

	.invite-sub {
		font-size: var(--text-sm);
		color: var(--gray-400);
		line-height: 1.5;
	}

	.invite-link {
		margin-top: 0.4rem;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--accent-regular);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.invite-link:hover { color: var(--accent-dark); }

	@media (min-width: 50em) {
		.invite-line { font-size: var(--text-xl); }
		.invite-sub, .invite-link { font-size: var(--text-md); }
	}

	/* ====================================================== */

	.section { display: grid; gap: 2rem; }
	.with-background { position: relative; }

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);
		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before { --hero-bg: var(--bg-image-subtle-1); }

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 { font-size: var(--text-2xl); }

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}
		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}
		.section-header { grid-area: header; font-size: var(--text-lg); }
		.section-header h3 { font-size: var(--text-4xl); }
		.with-cta .section-header { justify-self: flex-start; text-align: left; }
		.gallery { grid-area: gallery; }
		.cta { grid-area: cta; }
	}
</style>
