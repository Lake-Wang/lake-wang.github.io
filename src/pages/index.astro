---
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const allWork = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const experience = allWork.filter((e) => e.data.type === 'experience');
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Hello, my name is Yuxuan Wang"
					tagline="I am a Data Scientist specializing in clinical NLP and production ML — currently based in Phoenix, Arizona."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="terminal-window" size="1.33em" /> Data Scientist</Pill>
						<Pill><Icon icon="code" size="1.33em" /> ML Engineer</Pill>
						<Pill><Icon icon="pencil-line" size="1.33em" /> Researcher</Pill>
					</div>
				</Hero>

				<img
					alt="Yuxuan Wang"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Work Highlights</h3>
					<p>Current and most recent roles. The Work page has the full experience history and academic projects.</p>
				</header>

				<div class="gallery">
					<Grid>
						{experience.map((project) => (
							<li><PortfolioPreview project={project} /></li>
						))}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="domains">
				<h2 class="section-subhead">Application Domains</h2>
				<p class="domains-intro">The same ML and engineering discipline — applied across industries with fundamentally different data, constraints, and definitions of value. Healthcare, finance, and media each demanded a different intuition; the through-line is rigorous modeling and a focus on business outcomes over benchmark performance. Click any company to see the work.</p>

				<div class="hub-diagram">
					<svg viewBox="0 0 900 470" class="hub-svg" xmlns="http://www.w3.org/2000/svg">
						<defs>
							<style>
								.hub-ellipse { fill: var(--accent-regular); }
								.hub-text { fill: white; font-weight: 700; font-size: 26px; font-family: var(--font-brand), system-ui, sans-serif; }
								.spoke { fill: none; stroke-linecap: round; }
								.spoke-hc { stroke: var(--accent-regular); stroke-width: 5; opacity: 0.65; }
								.spoke-me { stroke: var(--gray-400); stroke-width: 3; opacity: 0.7; }
								.spoke-fi { stroke: var(--gray-500); stroke-width: 1.5; opacity: 0.55; }
								.ind-ellipse { fill: var(--gray-900); }
								.ie-hc { stroke: var(--accent-regular); stroke-width: 2.5; }
								.ie-me { stroke: var(--gray-600); stroke-width: 1.5; }
								.ie-fi { stroke: var(--gray-700); stroke-width: 1; }
								.ttl { font-family: var(--font-brand), system-ui, sans-serif; fill: var(--gray-0); font-weight: 700; }
								.ttl-lg { font-size: 20px; }
								.ttl-md { font-size: 16px; }
								.ttl-sm { font-size: 15px; }
								.desc { fill: var(--gray-200); font-size: 12px; font-family: system-ui, sans-serif; }
								.chip { fill: var(--gray-700); }
								.chip-txt { fill: var(--gray-300); font-size: 11px; font-family: var(--font-brand), system-ui, sans-serif; }
								.chip-lnk { cursor: pointer; text-decoration: none; }
								.chip-lnk:hover .chip { fill: var(--accent-regular); }
								.chip-lnk:hover .chip-txt { fill: white; }
								.ttl-lnk { cursor: pointer; text-decoration: none; }
								.ttl-lnk:hover .ttl { fill: var(--accent-regular); }
							</style>
						</defs>

						<!-- Central hub -->
						<ellipse cx="450" cy="80" rx="130" ry="55" class="hub-ellipse" />
						<text x="450" y="88" text-anchor="middle" class="hub-text">AI / ML</text>

						<!-- Spokes (hub edge → industry ellipse edge) -->
						<line x1="353" y1="117" x2="255" y2="289" class="spoke spoke-hc" />
						<line x1="450" y1="135" x2="450" y2="295" class="spoke spoke-me" />
						<line x1="548" y1="117" x2="647" y2="296" class="spoke spoke-fi" />

						<!-- ── Healthcare ── -->
						<ellipse cx="150" cy="345" rx="140" ry="85" class="ind-ellipse ie-hc" />
						<a href="/work/bloom-box/" class="ttl-lnk">
							<text x="150" y="322" text-anchor="middle" class="ttl ttl-lg">Healthcare</text>
						</a>
						<text x="150" y="342" text-anchor="middle" class="desc">Clinical NLP · medical coding</text>
						<text x="150" y="357" text-anchor="middle" class="desc">automation · glucose prediction</text>
						<a href="/work/bloom-box/" class="chip-lnk">
							<rect x="77" y="373" width="82" height="19" rx="5" class="chip" />
							<text x="118" y="386" text-anchor="middle" class="chip-txt">XpertDox</text>
						</a>
						<a href="/work/#fosun" class="chip-lnk">
							<rect x="168" y="373" width="58" height="19" rx="5" class="chip" />
							<text x="197" y="386" text-anchor="middle" class="chip-txt">Fosun</text>
						</a>

						<!-- ── Media & Entertainment ── -->
						<ellipse cx="450" cy="368" rx="122" ry="73" class="ind-ellipse ie-me" />
						<a href="/work/h20/" class="ttl-lnk">
							<text x="450" y="348" text-anchor="middle" class="ttl ttl-md">Media &amp;</text>
							<text x="450" y="366" text-anchor="middle" class="ttl ttl-md">Entertainment</text>
						</a>
						<text x="450" y="384" text-anchor="middle" class="desc">Hierarchical demand forecasting</text>
						<text x="450" y="397" text-anchor="middle" class="desc">across 11 digital platforms</text>
						<a href="/work/h20/" class="chip-lnk">
							<rect x="386" y="411" width="128" height="19" rx="5" class="chip" />
							<text x="450" y="424" text-anchor="middle" class="chip-txt">NBCUniversal</text>
						</a>

						<!-- ── Finance ── -->
						<ellipse cx="750" cy="340" rx="110" ry="65" class="ind-ellipse ie-fi" />
						<a href="/work/#haitong-securities" class="ttl-lnk">
							<text x="750" y="322" text-anchor="middle" class="ttl ttl-sm">Finance</text>
						</a>
						<text x="750" y="340" text-anchor="middle" class="desc">Deep RL for quantitative</text>
						<text x="750" y="354" text-anchor="middle" class="desc">trading strategy</text>
						<a href="/work/#haitong-securities" class="chip-lnk">
							<rect x="672" y="368" width="156" height="19" rx="5" class="chip" />
							<text x="750" y="381" text-anchor="middle" class="chip-txt">Haitong Securities</text>
						</a>
					</svg>
				</div>
			</section>

			<section class="education">
				<h2 class="section-subhead">Education</h2>
				<div class="edu-entries">
					<div class="edu-entry">
						<div class="edu-row">
							<span class="edu-school">New York University</span>
							<span class="edu-dates">2023 – 2025</span>
						</div>
						<p class="edu-degree">M.S. Data Science &nbsp;·&nbsp; GPA 3.95</p>
						<p class="edu-note">ML System Design · NLP · Deep Learning &nbsp;·&nbsp; TA: Big Data, Intro to Data Science</p>
					</div>
					<div class="edu-entry">
						<div class="edu-row">
							<span class="edu-school">NYU Shanghai</span>
							<span class="edu-dates">2018 – 2022</span>
						</div>
						<p class="edu-degree">B.S. Data Science (AI) &amp; Economics &nbsp;·&nbsp; GPA 3.69</p>
						<p class="edu-note">Reinforcement Learning · Database · Machine Learning · Econometrics</p>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles { display: none; }

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}
		.roles { margin-top: 0.5rem; display: flex; gap: 0.5rem; }
		.hero img { aspect-ratio: 3 / 4; border-radius: 4.5rem; object-fit: cover; }
	}

	/* ====================================================== */

	.section-subhead {
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.section-subhead { font-size: var(--text-2xl); }
	}

	/* ====================================================== */

	.domains {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.domains-intro {
		font-size: var(--text-sm);
		color: var(--gray-400);
		max-width: 68ch;
		line-height: 1.6;
	}

	@media (min-width: 50em) {
		.domains-intro { font-size: var(--text-md); }
	}

	.hub-diagram { width: 100%; }

	.hub-svg {
		width: 100%;
		height: auto;
		display: block;
		overflow: visible;
	}

	/* ====================================================== */

	.education {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.edu-entries {
		display: flex;
		flex-direction: column;
		border-top: 1px dashed var(--gray-700);
	}

	.edu-entry {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 1rem 0;
		border-bottom: 1px dashed var(--gray-700);
	}

	.edu-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}

	.edu-school { font-size: var(--text-md); font-weight: 600; color: var(--gray-0); }
	.edu-dates { font-size: var(--text-sm); color: var(--gray-400); font-family: var(--font-brand); flex-shrink: 0; }
	.edu-degree { font-size: var(--text-sm); color: var(--gray-300); }
	.edu-note { font-size: var(--text-sm); color: var(--gray-400); margin-top: 0.1rem; }

	@media (min-width: 50em) {
		.edu-school { font-size: var(--text-lg); }
		.edu-degree, .edu-note { font-size: var(--text-md); }
	}

	/* ====================================================== */

	.section { display: grid; gap: 2rem; }

	.with-background { position: relative; }

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);
		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before { --hero-bg: var(--bg-image-subtle-1); }

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 { font-size: var(--text-2xl); }

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}
		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}
		.section-header { grid-area: header; font-size: var(--text-lg); }
		.section-header h3 { font-size: var(--text-4xl); }
		.with-cta .section-header { justify-self: flex-start; text-align: left; }
		.gallery { grid-area: gallery; }
		.cta { grid-area: cta; }
	}
</style>
