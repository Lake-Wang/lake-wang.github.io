---
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const allWork = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const experience = allWork.filter((e) => e.data.type === 'experience');
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Hello, my name is Yuxuan Wang"
					tagline="I am a Data Scientist specializing in clinical NLP and production ML — currently based in Phoenix, Arizona."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="terminal-window" size="1.33em" /> Data Scientist</Pill>
						<Pill><Icon icon="code" size="1.33em" /> ML Engineer</Pill>
						<Pill><Icon icon="pencil-line" size="1.33em" /> Researcher</Pill>
					</div>
				</Hero>

				<img
					alt="Yuxuan Wang"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Work Highlights</h3>
					<p>Current and most recent roles. The Work page has the full experience history and academic projects.</p>
				</header>

				<div class="gallery">
					<Grid>
						{experience.map((project) => (
							<li><PortfolioPreview project={project} /></li>
						))}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="domains">
				<h2 class="section-subhead">Application Domains</h2>
				<p class="domains-intro">ML and data science applied outside of pure tech — three industries where domain fluency and business translation matter as much as model performance.</p>

				<!-- Desktop: hub-and-spoke SVG diagram -->
				<div class="hub-diagram">
					<svg viewBox="0 0 900 440" class="hub-svg" xmlns="http://www.w3.org/2000/svg">
						<defs>
							<style>
								.hub-ellipse { fill: var(--accent-regular); }
								.hub-text { fill: white; font-weight: 700; font-size: 22px; font-family: var(--font-brand), system-ui, sans-serif; }
								.spoke { fill: none; stroke-linecap: round; }
								.spoke-hc { stroke: var(--accent-regular); stroke-width: 5; opacity: 0.65; }
								.spoke-me { stroke: var(--gray-400); stroke-width: 3; opacity: 0.7; }
								.spoke-fi { stroke: var(--gray-500); stroke-width: 1.5; opacity: 0.55; }
								.card { transition: stroke 0.2s ease; }
								.card-hc { fill: var(--gray-900); stroke: var(--accent-regular); stroke-width: 2; }
								.card-me { fill: var(--gray-900); stroke: var(--gray-600); stroke-width: 1.5; }
								.card-fi { fill: var(--gray-900); stroke: var(--gray-700); stroke-width: 1; }
								.lnk-hc:hover .card-hc { stroke-width: 3; }
								.lnk-me:hover .card-me,
								.lnk-fi:hover .card-fi { stroke: var(--accent-regular); stroke-width: 2; }
								.lnk-hc, .lnk-me, .lnk-fi { cursor: pointer; }
								.ttl { font-family: var(--font-brand), system-ui, sans-serif; fill: var(--gray-0); font-weight: 700; }
								.ttl-lg { font-size: 20px; }
								.ttl-md { font-size: 16px; }
								.ttl-sm { font-size: 14px; }
								.desc { fill: var(--gray-200); font-size: 12.5px; font-family: system-ui, sans-serif; }
								.chip { fill: var(--gray-700); }
								.chip-txt { fill: var(--gray-300); font-size: 11px; font-family: var(--font-brand), system-ui, sans-serif; }
							</style>
						</defs>

						<!-- Central hub -->
						<ellipse cx="450" cy="68" rx="135" ry="42" class="hub-ellipse" />
						<text x="450" y="76" text-anchor="middle" class="hub-text">AI / ML</text>

						<!-- Spoke lines -->
						<line x1="355" y1="106" x2="158" y2="252" class="spoke spoke-hc" />
						<line x1="450" y1="110" x2="450" y2="256" class="spoke spoke-me" />
						<line x1="545" y1="106" x2="742" y2="256" class="spoke spoke-fi" />

						<!-- Healthcare card (primary, largest) -->
						<a href="/work/#fosun" class="lnk-hc">
							<rect x="22" y="252" width="272" height="172" rx="14" class="card card-hc" />
							<text x="158" y="287" text-anchor="middle" class="ttl ttl-lg">Healthcare</text>
							<text x="158" y="308" text-anchor="middle" class="desc">Clinical NLP · medical coding</text>
							<text x="158" y="324" text-anchor="middle" class="desc">automation · glucose prediction</text>
							<!-- Chips -->
							<rect x="48" y="340" width="86" height="22" rx="5" class="chip" />
							<text x="91" y="355" text-anchor="middle" class="chip-txt">XpertDox</text>
							<rect x="146" y="340" width="54" height="22" rx="5" class="chip" />
							<text x="173" y="355" text-anchor="middle" class="chip-txt">Fosun</text>
						</a>

						<!-- Media card (secondary) -->
						<a href="/work/" class="lnk-me">
							<rect x="330" y="256" width="240" height="162" rx="12" class="card card-me" />
							<text x="450" y="287" text-anchor="middle" class="ttl ttl-md">Media &amp;</text>
							<text x="450" y="305" text-anchor="middle" class="ttl ttl-md">Entertainment</text>
							<text x="450" y="326" text-anchor="middle" class="desc">Hierarchical demand forecasting</text>
							<text x="450" y="342" text-anchor="middle" class="desc">across 11 digital platforms</text>
							<!-- Chip -->
							<rect x="349" y="358" width="202" height="22" rx="5" class="chip" />
							<text x="450" y="373" text-anchor="middle" class="chip-txt">NBCUniversal</text>
						</a>

						<!-- Finance card (tertiary, smallest) -->
						<a href="/work/#haitong-securities" class="lnk-fi">
							<rect x="606" y="256" width="272" height="136" rx="12" class="card card-fi" />
							<text x="742" y="285" text-anchor="middle" class="ttl ttl-sm">Finance</text>
							<text x="742" y="303" text-anchor="middle" class="desc">Deep RL for quantitative</text>
							<text x="742" y="319" text-anchor="middle" class="desc">trading strategy</text>
							<!-- Chip -->
							<rect x="633" y="334" width="218" height="22" rx="5" class="chip" />
							<text x="742" y="349" text-anchor="middle" class="chip-txt">Haitong Securities</text>
						</a>
					</svg>
				</div>

				<!-- Mobile: stacked cards (SVG doesn't scale well on narrow viewports) -->
				<div class="domain-cards-mobile">
					<a href="/work/#fosun" class="domain-card-m">
						<span class="dcm-label">Healthcare</span>
						<p class="dcm-desc">Clinical NLP and medical coding automation; predictive modeling for non-invasive medical devices</p>
						<div class="dcm-orgs"><span>XpertDox</span><span>Fosun</span></div>
					</a>
					<a href="/work/" class="domain-card-m">
						<span class="dcm-label">Media & Entertainment</span>
						<p class="dcm-desc">Hierarchical demand forecasting across 11 digital streaming platforms</p>
						<div class="dcm-orgs"><span>NBCUniversal</span></div>
					</a>
					<a href="/work/#haitong-securities" class="domain-card-m">
						<span class="dcm-label">Finance</span>
						<p class="dcm-desc">Deep RL for quantitative trading strategy</p>
						<div class="dcm-orgs"><span>Haitong Securities</span></div>
					</a>
				</div>
			</section>

			<section class="education">
				<h2 class="section-subhead">Education</h2>
				<div class="edu-entries">
					<div class="edu-entry">
						<div class="edu-row">
							<span class="edu-school">New York University</span>
							<span class="edu-dates">2023 – 2025</span>
						</div>
						<p class="edu-degree">M.S. Data Science &nbsp;·&nbsp; GPA 3.95</p>
						<p class="edu-note">ML System Design · NLP · Deep Learning &nbsp;·&nbsp; TA: Big Data, Intro to Data Science</p>
					</div>
					<div class="edu-entry">
						<div class="edu-row">
							<span class="edu-school">NYU Shanghai</span>
							<span class="edu-dates">2018 – 2022</span>
						</div>
						<p class="edu-degree">B.S. Data Science (AI) &amp; Economics &nbsp;·&nbsp; GPA 3.69</p>
						<p class="edu-note">Reinforcement Learning · Database · Machine Learning · Econometrics</p>
					</div>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles { display: none; }

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}
		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}
		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section-subhead {
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	@media (min-width: 50em) {
		.section-subhead { font-size: var(--text-2xl); }
	}

	/* ====================================================== */

	.domains {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.domains-intro {
		font-size: var(--text-sm);
		color: var(--gray-400);
		max-width: 60ch;
	}

	@media (min-width: 50em) {
		.domains-intro { font-size: var(--text-md); }
	}

	/* Hub diagram — desktop only */
	.hub-diagram { display: none; }
	.domain-cards-mobile { display: flex; flex-direction: column; gap: 1rem; }

	@media (min-width: 50em) {
		.hub-diagram { display: block; }
		.domain-cards-mobile { display: none; }
	}

	.hub-svg {
		width: 100%;
		height: auto;
		display: block;
		overflow: visible;
	}

	/* Mobile fallback cards */
	.domain-card-m {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		padding: 1.1rem 1.25rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.9rem;
		background: var(--gradient-subtle);
		text-decoration: none;
	}

	.dcm-label {
		font-size: var(--text-lg);
		font-weight: 700;
		font-family: var(--font-brand);
		color: var(--gray-0);
	}

	.dcm-desc {
		font-size: var(--text-sm);
		color: var(--gray-300);
		line-height: 1.5;
	}

	.dcm-orgs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.2rem;
	}

	.dcm-orgs span {
		font-size: var(--text-sm);
		color: var(--gray-400);
		background: var(--gray-900);
		padding: 0.1rem 0.55rem;
		border-radius: 0.35rem;
	}

	/* ====================================================== */

	.education {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.edu-entries {
		display: flex;
		flex-direction: column;
		border-top: 1px dashed var(--gray-700);
	}

	.edu-entry {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 1rem 0;
		border-bottom: 1px dashed var(--gray-700);
	}

	.edu-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}

	.edu-school {
		font-size: var(--text-md);
		font-weight: 600;
		color: var(--gray-0);
	}

	.edu-dates {
		font-size: var(--text-sm);
		color: var(--gray-400);
		font-family: var(--font-brand);
		flex-shrink: 0;
	}

	.edu-degree {
		font-size: var(--text-sm);
		color: var(--gray-300);
	}

	.edu-note {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin-top: 0.1rem;
	}

	@media (min-width: 50em) {
		.edu-school { font-size: var(--text-lg); }
		.edu-degree, .edu-note { font-size: var(--text-md); }
	}

	/* ====================================================== */

	.section { display: grid; gap: 2rem; }

	.with-background { position: relative; }

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);
		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before { --hero-bg: var(--bg-image-subtle-1); }

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 { font-size: var(--text-2xl); }

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}
		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}
		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}
		.section-header h3 { font-size: var(--text-4xl); }
		.with-cta .section-header { justify-self: flex-start; text-align: left; }
		.gallery { grid-area: gallery; }
		.cta { grid-area: cta; }
	}
</style>
