---
const skillCategories = [
	{
		label: 'Programming',
		skills: ['Python', 'SQL'],
	},
	{
		label: 'ML / AI',
		skills: ['PyTorch', 'scikit-learn', 'XGBoost', 'Transformers', 'ONNX'],
	},
	{
		label: 'MLOps',
		skills: ['MLflow', 'FastAPI', 'Prometheus'],
	},
	{
		label: 'Data Engineering',
		skills: ['Spark', 'pandas'],
	},
	{
		label: 'Statistics',
		skills: ['Time Series', 'Hypothesis Testing', 'Regression', 'Reinforcement Learning'],
	},
	{
		label: 'Viz',
		skills: ['Tableau', 'matplotlib'],
	},
	{
		label: 'Spoken',
		skills: ['Mandarin · Native', 'English · Native'],
	},
];
---

<section class="skills-table">
	{skillCategories.map((category) => (
		<div class="skill-row">
			<span class="category-label">{category.label}</span>
			<div class="skill-pills">
				{category.skills.map((skill) => (
					<span class="skill-pill">{skill}</span>
				))}
			</div>
		</div>
	))}
</section>

<style>
	.skills-table {
		display: flex;
		flex-direction: column;
		border-top: 1px dashed var(--gray-700);
		width: 100%;
	}

	.skill-row {
		display: flex;
		align-items: flex-start;
		gap: 2rem;
		padding: 1rem 0;
		border-bottom: 1px dashed var(--gray-700);
	}

	.category-label {
		font-size: var(--text-xs);
		font-family: var(--font-brand);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--gray-400);
		min-width: 9rem;
		flex-shrink: 0;
		padding-top: 0.3rem;
	}

	.skill-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.skill-pill {
		font-size: var(--text-sm);
		font-family: var(--font-brand);
		border: 1px solid var(--gray-700);
		border-radius: 0.375rem;
		padding: 0.2rem 0.7rem;
		color: var(--gray-200);
		background: transparent;
	}

	@media (max-width: 50em) {
		.skill-row {
			flex-direction: column;
			gap: 0.6rem;
		}

		.category-label {
			min-width: unset;
		}
	}
</style>
